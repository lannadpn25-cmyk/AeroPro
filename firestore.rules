rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Global utility validation functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(data) {
      return (request.auth != null && data.userId == request.auth.uid) || 
             (request.auth == null && data.userId is string);
    }

    // 1. Weekly Goals Validation Rules
    match /weeklyGoals/{userId} {
      allow get: if isValidId(userId) && (request.auth == null || request.auth.uid == userId);
      allow create, update: if isValidId(userId) && 
        (request.auth == null || request.auth.uid == userId) &&
        incoming().userId == userId &&
        incoming().targetMinutes is number &&
        incoming().targetDistanceKm is number &&
        incoming().targetWorkoutsCount is number;
      allow delete: if false; // Weekly goals shouldn't be deleted
    }

    // 2. Activities Validation Rules
    match /activities/{activityId} {
      allow get: if isValidId(activityId) && isOwner(existing());
      allow list: if isOwner(resource.data);
      allow create: if isValidId(activityId) &&
        isOwner(incoming()) &&
        incoming().id == activityId &&
        incoming().name is string &&
        incoming().name.size() > 0 &&
        incoming().type is string;
      allow update: if isValidId(activityId) &&
        isOwner(existing()) &&
        isOwner(incoming()) &&
        incoming().userId == existing().userId &&
        incoming().name is string &&
        incoming().type is string;
      allow delete: if isValidId(activityId) && isOwner(existing());
    }

    // 3. Templates Validation Rules
    match /templates/{templateId} {
      allow get: if isValidId(templateId) && isOwner(existing());
      allow list: if isOwner(resource.data);
      allow create: if isValidId(templateId) &&
        isOwner(incoming()) &&
        incoming().id == templateId &&
        incoming().name is string &&
        incoming().type is string;
      allow update: if isValidId(templateId) &&
        isOwner(existing()) &&
        isOwner(incoming()) &&
        incoming().userId == existing().userId &&
        incoming().name is string &&
        incoming().type is string;
      allow delete: if isValidId(templateId) && isOwner(existing());
    }

    // 4. Completed Workouts Validation Rules
    match /completedWorkouts/{workoutId} {
      allow get: if isValidId(workoutId) && isOwner(existing());
      allow list: if isOwner(resource.data);
      allow create: if isValidId(workoutId) &&
        isOwner(incoming()) &&
        incoming().id == workoutId &&
        incoming().workoutName is string &&
        incoming().actualDurationMinutes is number;
      allow update: if isValidId(workoutId) &&
        isOwner(existing()) &&
        isOwner(incoming()) &&
        incoming().userId == existing().userId &&
        incoming().workoutName is string;
      allow delete: if isValidId(workoutId) && isOwner(existing());
    }
  }
}
